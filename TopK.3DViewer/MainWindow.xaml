<Window x:Class="TopK.ThreeDViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="TopK 3D Viewer" Height="940" Width="1720"
        MinHeight="720" MinWidth="1250" WindowStartupLocation="CenterScreen">
    <Grid Background="#EEF2F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,5">
                <TextBlock Text="TopK.3DViewer" FontSize="18" FontWeight="SemiBold"
                           Foreground="#1E3A5F" VerticalAlignment="Center" Margin="4,0,20,0" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <CheckBox x:Name="ChkShowObstacles" Content="선택 경로 주변 장애물" IsChecked="True" Margin="10,0"
                              VerticalAlignment="Center" Checked="ObstacleToggle_Changed" Unchecked="ObstacleToggle_Changed" />
                    <CheckBox x:Name="ChkShowBendFeatures" Content="꺾임원인 표시" IsChecked="True" Margin="10,0"
                              VerticalAlignment="Center" Checked="BendFeatureToggle_Changed" Unchecked="BendFeatureToggle_Changed"
                              ToolTip="TB_ROUTE_BEND_FEATURE_POINT: 주황=장애물회피, 초록=목적지진입, 파랑=구역경계, 보라=그룹정렬, 회색=미분류" />
                    <CheckBox x:Name="ChkShowPathSegments" Content="구간분할 표시" IsChecked="False" Margin="10,0"
                              VerticalAlignment="Center" Checked="PathSegmentToggle_Changed" Unchecked="PathSegmentToggle_Changed"
                              ToolTip="TB_ROUTE_PATH_SEGMENTATION: 노랑=Start Stub, 흰색=Middle Trunk, 청록=End Stub (개별/그룹 모드에서 선택된 route에 오버레이)" />
                    <CheckBox x:Name="ChkShowAllRoutes" Content="Top-K 전체 표시" IsChecked="True" Margin="10,0"
                              VerticalAlignment="Center" Checked="RouteDisplay_Changed" Unchecked="RouteDisplay_Changed" />
                    <Button Content="카메라 맞춤" Click="ZoomExtents_Click" />
                    <Button Content="초기화" Click="ClearViewer_Click" />
                    <Button Content="특징점생성" Click="FeatureGeneration_Click" />
                </StackPanel>
                <TextBlock x:Name="TxtActiveScope" Text="ACTIVE scope: 연결 후 확인"
                           Foreground="#53657A" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <!-- 좌측: DB와 검색조건 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="{StaticResource PanelBrush}">
                <StackPanel Margin="5">
                    <GroupBox Header="PostgreSQL 연결">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="65" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Host" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtHost" Grid.Column="1" />
                            <TextBox x:Name="TxtPort" Grid.Column="2" />
                            <TextBlock Grid.Row="1" Text="Database" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtDatabase" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" />
                            <TextBlock Grid.Row="2" Text="User" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtUser" Grid.Row="2" Grid.Column="1" Margin="3,3,43,3" />
                            <PasswordBox x:Name="TxtPassword" Grid.Row="2" Grid.Column="1" Margin="97,3,3,3" Padding="5,3" Grid.ColumnSpan="2" />
                            <Button Grid.Row="3" Grid.ColumnSpan="3" Content="DB 연결 및 조건 로드"
                                    Background="#1976D2" Foreground="White" Click="Connect_Click" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="검색 단위">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RdoIndividualMode" Content="개별 배관" GroupName="SearchUnit"
                                             IsChecked="True" Margin="5,3,18,3" Checked="SearchMode_Changed" />
                                <RadioButton x:Name="RdoGroupMode" Content="Utility 배관 그룹" GroupName="SearchUnit"
                                             Margin="5,3" Checked="SearchMode_Changed" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RdoGroupPatternMode" Content="다발배관 패턴" GroupName="SearchUnit"
                                             Margin="5,3,18,3" Checked="SearchMode_Changed" />
                                <RadioButton x:Name="RdoStubPatternMode" Content="Stub 패턴" GroupName="SearchUnit"
                                             Margin="5,3" Checked="SearchMode_Changed" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpRoutePreset" Header="기존 Route 프리셋">
                        <StackPanel>
                            <ComboBox x:Name="CmbPreset" DisplayMemberPath="Display"
                                      SelectionChanged="Preset_SelectionChanged" />
                            <TextBlock Text="선택하면 아래 검색조건과 시작/종점 좌표를 자동 입력합니다."
                                       Foreground="#66788A" TextWrapping="Wrap" Margin="4" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpGroupPreset" Header="Utility 배관 그룹 프리셋" Visibility="Collapsed">
                        <StackPanel>
                            <ComboBox x:Name="CmbGroupPreset" DisplayMemberPath="Display"
                                      SelectionChanged="GroupPreset_SelectionChanged" />
                            <TextBlock Text="장비 + Utility Group + Utility에 속한 여러 배관을 하나의 Query로 사용합니다."
                                       Foreground="#66788A" TextWrapping="Wrap" Margin="4" />
                            <DataGrid x:Name="GridGroupMembers" Height="135" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="30" />
                                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="48" />
                                    <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern}" Width="*" />
                                    <DataGridTextColumn Header="Route" Binding="{Binding ShortGuid}" Width="95" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpGroupPatternPreset" Header="다발배관 패턴 프리셋" Visibility="Collapsed">
                        <StackPanel>
                            <ComboBox x:Name="CmbGroupPatternPreset" DisplayMemberPath="Display"
                                      SelectionChanged="GroupPatternPreset_SelectionChanged" />
                            <TextBlock Text="TB_ROUTE_GROUP_PATTERN 중 하나를 고르면 그 형상(FEAT)을 Query로 삼아 비슷한 평행구간을 찾습니다."
                                       Foreground="#66788A" TextWrapping="Wrap" Margin="4" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpStubPatternPreset" Header="Stub 패턴 프리셋" Visibility="Collapsed">
                        <StackPanel>
                            <ComboBox x:Name="CmbStubPatternPreset" DisplayMemberPath="Display"
                                      SelectionChanged="StubPatternPreset_SelectionChanged" />
                            <TextBlock Text="TB_ROUTE_STUB_PATTERN 중 하나를 고르면 그 형상(FEAT+DIR_UNIT)을 Query로 삼아 비슷한 Stub을 찾습니다."
                                       Foreground="#66788A" TextWrapping="Wrap" Margin="4" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpFilters" Header="검색 필터">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="공정" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbProcess" Grid.Column="1" IsEditable="True" />
                            <TextBlock Grid.Row="1" Text="장비" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbEquipment" Grid.Row="1" Grid.Column="1" IsEditable="True" />
                            <TextBlock Grid.Row="2" Text="Utility Group" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbUtilityGroup" Grid.Row="2" Grid.Column="1" IsEditable="True" />
                            <TextBlock Grid.Row="3" Text="Utility" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbUtility" Grid.Row="3" Grid.Column="1" IsEditable="True" />
                            <TextBlock x:Name="LblSize" Grid.Row="4" Text="Size" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbSize" Grid.Row="4" Grid.Column="1" IsEditable="True" />
                            <TextBlock x:Name="LblPattern" Grid.Row="5" Text="방향 Pattern" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPattern" Grid.Row="5" Grid.Column="1" ToolTip="예: H-R-H" />
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="GrpCoordinates" Header="시작 / 종점 좌표 (mm)">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="1" Text="X" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Y" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Z" HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="1" Text="Start" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtStartX" Grid.Row="1" Grid.Column="1" />
                            <TextBox x:Name="TxtStartY" Grid.Row="1" Grid.Column="2" />
                            <TextBox x:Name="TxtStartZ" Grid.Row="1" Grid.Column="3" />
                            <TextBlock Grid.Row="2" Text="End" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtEndX" Grid.Row="2" Grid.Column="1" />
                            <TextBox x:Name="TxtEndY" Grid.Row="2" Grid.Column="2" />
                            <TextBox x:Name="TxtEndZ" Grid.Row="2" Grid.Column="3" />
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="GrpGroupOptions" Header="그룹 매칭 옵션" Visibility="Collapsed">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Size 정책" Width="105" VerticalAlignment="Center" />
                                <ComboBox x:Name="CmbGroupSizeMode" SelectedIndex="0"
                                          SelectionChanged="GroupOption_Changed">
                                    <ComboBoxItem Content="PreferExact" ToolTip="같은 Size를 우선하고 없으면 다른 Size도 허용" />
                                    <ComboBoxItem Content="ExactOnly" ToolTip="같은 Size끼리만 Pair 허용" />
                                    <ComboBoxItem Content="Ignore" ToolTip="Size를 Pair 점수에서 무시" />
                                </ComboBox>
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Pair 평균 %" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtGroupMatchedWeight" Grid.Column="1" Text="80"
                                         LostKeyboardFocus="GroupWeight_LostKeyboardFocus" />
                                <TextBlock Grid.Column="2" Text="배치 %" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtGroupArrangementWeight" Grid.Column="3" Text="20"
                                         LostKeyboardFocus="GroupWeight_LostKeyboardFocus" />
                            </Grid>
                            <DockPanel>
                                <TextBlock Text="3D 비교" Width="105" VerticalAlignment="Center" />
                                <ComboBox x:Name="CmbGroupViewMode" SelectedIndex="0"
                                          SelectionChanged="GroupOption_Changed">
                                    <ComboBoxItem Content="Original" ToolTip="Query와 Candidate를 실제 좌표에 표시" />
                                    <ComboBoxItem Content="SideBySide" ToolTip="Candidate를 Query 옆으로 평행 이동하여 형상 비교" />
                                </ComboBox>
                            </DockPanel>
                            <CheckBox x:Name="ChkShowUnmatchedGroupMembers" Content="미매칭 멤버 표시 (Query=빨강, Candidate=주황)"
                                      IsChecked="True" Checked="GroupOption_Changed" Unchecked="GroupOption_Changed" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpWeights" Header="유사도 가중치 (자동 정규화)">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Position" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtWeightPosition" Grid.Column="1" Text="25" ToolTip="시작~종점 상대변위 유사도" LostKeyboardFocus="WeightEditor_LostKeyboardFocus" />
                                <TextBlock Grid.Column="2" Text="Pattern" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtWeightPattern" Grid.Column="3" Text="25" ToolTip="방향 Pattern 유사도" LostKeyboardFocus="WeightEditor_LostKeyboardFocus" />
                                <TextBlock Grid.Row="1" Text="Feature" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtWeightVector" Grid.Row="1" Grid.Column="1" Text="25" ToolTip="30D Feature Vector 유사도" LostKeyboardFocus="WeightEditor_LostKeyboardFocus" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Context" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtWeightContext" Grid.Row="1" Grid.Column="3" Text="25" ToolTip="장애물 Context Vector 유사도" LostKeyboardFocus="WeightEditor_LostKeyboardFocus" />
                            </Grid>
                            <CheckBox x:Name="ChkRedistributeMissingPattern"
                                      Content="Pattern 미입력 시 해당 가중치 자동 재배분"
                                      IsChecked="True" Margin="4,5,4,2"
                                      Checked="SettingsOption_Changed" Unchecked="SettingsOption_Changed" />
                            <DockPanel>
                                <Button Content="모두 사용 (25/25/25/25)" Click="ResetWeights_Click"
                                        Padding="7,3" DockPanel.Dock="Right" />
                                <TextBlock Text="0=제외, 활성 항목은 균등 배분·자동 저장"
                                           Foreground="#66788A" VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="검색 옵션">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="K" Width="90" VerticalAlignment="Center" />
                                <TextBox x:Name="TxtK" Text="5" />
                            </DockPanel>
                            <CheckBox x:Name="ChkUseContext" Content="장애물 Context Vector 재정렬"
                                      IsChecked="True" Margin="4,6" />
                            <CheckBox x:Name="ChkAutoZoom" Content="검색 후 자동 카메라 맞춤"
                                      IsChecked="True" Margin="4,3" />
                            <Button x:Name="BtnSearch" Content="Top-K 검색 및 3D 로드"
                                    FontWeight="Bold" FontSize="14" Height="42"
                                    Background="#1565C0" Foreground="White" Click="Search_Click" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#C8D0DA" />

            <!-- 중앙: 3D -->
            <Border Grid.Column="2" Background="#172B4D" BorderBrush="#9AA8B8" BorderThickness="1">
                <Grid>
                    <h:HelixViewport3D x:Name="Viewport" Background="#172B4D"
                                       ShowCoordinateSystem="True" ShowViewCube="True"
                                       IsHeadLightEnabled="True" ZoomExtentsWhenLoaded="True">
                        <h:HelixViewport3D.Camera>
                            <PerspectiveCamera Position="15000,15000,12000"
                                               LookDirection="-15000,-15000,-9000"
                                               UpDirection="0,0,1" FieldOfView="45" />
                        </h:HelixViewport3D.Camera>
                        <h:SunLight />
                        <h:GridLinesVisual3D x:Name="SceneGrid" Width="20000" Length="20000" MinorDistance="1000"
                                             MajorDistance="5000" Thickness="0.4" Fill="#445A78" />
                        <ModelVisual3D x:Name="ObstacleLayer" />
                        <ModelVisual3D x:Name="PresetRouteLayer" />
                        <ModelVisual3D x:Name="RouteLayer" />
                        <ModelVisual3D x:Name="MarkerLayer" />
                        <ModelVisual3D x:Name="BendFeatureLayer" />
                        <ModelVisual3D x:Name="PathSegmentLayer" />
                    </h:HelixViewport3D>

                    <!-- 색상 범례: 각 그룹은 해당 표시 체크박스 상태에 맞춰 코드비하인드에서 Visibility를 갱신한다. -->
                    <Border Background="#D0122642" BorderBrush="#5A7290" BorderThickness="1" CornerRadius="4"
                            Padding="10,8" Margin="12" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            IsHitTestVisible="False">
                        <StackPanel>
                            <TextBlock Text="색상 범례" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />

                            <StackPanel x:Name="LegendMarkers" Margin="0,0,0,6">
                                <TextBlock Text="시작 / 종점 마커" Foreground="#AEC3DC" FontSize="11" Margin="0,0,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Ellipse Width="12" Height="12" Fill="LimeGreen" Margin="0,0,6,0" />
                                    <TextBlock Text="시작점 (Start)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Ellipse Width="12" Height="12" Fill="OrangeRed" Margin="0,0,6,0" />
                                    <TextBlock Text="종점 (End)" Foreground="White" FontSize="11" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LegendBendFeature" Margin="0,0,0,6">
                                <TextBlock Text="꺾임원인 (Bend Cause)" Foreground="#AEC3DC" FontSize="11" Margin="0,0,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="11" Height="11" Fill="OrangeRed" Margin="0,0,6,0" />
                                    <TextBlock Text="장애물회피 (OBSTACLE_AVOID)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="11" Height="11" Fill="LimeGreen" Margin="0,0,6,0" />
                                    <TextBlock Text="목적지진입 (DESTINATION_ENTRY)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="11" Height="11" Fill="DeepSkyBlue" Margin="0,0,6,0" />
                                    <TextBlock Text="구역경계 (ZONE_CONSTRAINT)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="11" Height="11" Fill="MediumPurple" Margin="0,0,6,0" />
                                    <TextBlock Text="그룹정렬 (GROUP_ALIGNMENT)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="11" Height="11" Fill="Gainsboro" Margin="0,0,6,0" />
                                    <TextBlock Text="미분류" Foreground="White" FontSize="11" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LegendPathSegment" Margin="0,0,0,6" Visibility="Collapsed">
                                <TextBlock Text="구간분할 (Path Segment)" Foreground="#AEC3DC" FontSize="11" Margin="0,0,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="16" Height="6" Fill="Gold" Margin="0,0,6,0" />
                                    <TextBlock Text="Start Stub" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="16" Height="6" Fill="WhiteSmoke" Margin="0,0,6,0" />
                                    <TextBlock Text="Middle Trunk" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="16" Height="6" Fill="Cyan" Margin="0,0,6,0" />
                                    <TextBlock Text="End Stub" Foreground="White" FontSize="11" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LegendObstacles">
                                <TextBlock Text="주변 장애물 (BIM)" Foreground="#AEC3DC" FontSize="11" Margin="0,0,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="12" Height="12" Fill="#7D8C9B" Margin="0,0,6,0" />
                                    <TextBlock Text="기둥 (Column)" Foreground="White" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <Rectangle Width="12" Height="12" Fill="#C86363" Margin="0,0,6,0" />
                                    <TextBlock Text="보 (Beam)" Foreground="White" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#C8D0DA" />

            <!-- 우측: 결과와 상세 -->
            <Grid Grid.Column="4" Background="{StaticResource PanelBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <GroupBox Header="Top-K 검색 결과" Grid.Row="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtResultSummary" Text="검색 전"
                                   Foreground="#53657A" Margin="5,2,5,6" />
                        <DataGrid x:Name="GridResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionChanged="Results_SelectionChanged"
                                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                                  RowHeight="34" AlternatingRowBackground="#F2F6FA">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="ToolTip" Value="{Binding Guid}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DCEEFF" />
                                            <Setter Property="Foreground" Value="#0B3558" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="35" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F4}" Width="65" />
                                <DataGridTextColumn Header="Ctx" Binding="{Binding ContextScore, StringFormat=F3}" Width="55" />
                                <DataGridTextColumn Header="시작 장비" Binding="{Binding Equipment}" Width="*" />
                                <DataGridTextColumn Header="종단 객체" Binding="{Binding TargetDisplay}" Width="*" />
                                <DataGridTextColumn Header="Utility" Binding="{Binding Utility}" Width="75" />
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="50" />
                                <DataGridTextColumn Header="3D" Binding="{Binding GeometryLabel}" Width="55" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid x:Name="GridGroupResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                                  Visibility="Collapsed" SelectionMode="Single"
                                  SelectionChanged="GroupResults_SelectionChanged"
                                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                                  RowHeight="34" AlternatingRowBackground="#F2F6FA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="30" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F4}" Width="58" />
                                <DataGridTextColumn Header="매칭" Binding="{Binding MatchedLabel}" Width="62" />
                                <DataGridTextColumn Header="Cov" Binding="{Binding Coverage, StringFormat=F2}" Width="44" />
                                <DataGridTextColumn Header="Arr" Binding="{Binding Arrangement, StringFormat=F2}" Width="44" />
                                <DataGridTextColumn Header="시작 장비" Binding="{Binding Equipment}" Width="95" />
                                <DataGridTextColumn Header="종단 객체" Binding="{Binding TargetSummary}" Width="120" />
                                <DataGridTextColumn Header="Sizes" Binding="{Binding Sizes}" Width="95" />
                                <DataGridTextColumn Header="3D" Binding="{Binding GeometryLabel}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid x:Name="GridGroupPatternResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                                  Visibility="Collapsed" SelectionMode="Single"
                                  SelectionChanged="GroupPatternResults_SelectionChanged"
                                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                                  RowHeight="34" AlternatingRowBackground="#F2F6FA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="30" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F4}" Width="60" />
                                <DataGridTextColumn Header="장비" Binding="{Binding Equipment}" Width="85" />
                                <DataGridTextColumn Header="본수" Binding="{Binding NMembers}" Width="45" />
                                <DataGridTextColumn Header="Pitch" Binding="{Binding PitchMm, StringFormat=F0}" Width="55" />
                                <DataGridTextColumn Header="간격" Binding="{Binding SpacingLabel}" Width="60" />
                                <DataGridTextColumn Header="축" Binding="{Binding OffsetAxis}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid x:Name="GridStubPatternResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                                  Visibility="Collapsed" SelectionMode="Single"
                                  SelectionChanged="StubPatternResults_SelectionChanged"
                                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                                  RowHeight="34" AlternatingRowBackground="#F2F6FA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="30" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F4}" Width="60" />
                                <DataGridTextColumn Header="장비" Binding="{Binding MainEquipmentName}" Width="85" />
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="48" />
                                <DataGridTextColumn Header="Face" Binding="{Binding Face}" Width="48" />
                                <DataGridTextColumn Header="Dir Seq" Binding="{Binding DirSeq}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
                <GroupBox Header="선택 경로 상세" Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="TxtDetails" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" TextWrapping="Wrap" AcceptsReturn="True"
                                 FontFamily="Consolas" VerticalScrollBarVisibility="Auto" />
                    </ScrollViewer>
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#243B55">
            <DockPanel Margin="8,0">
                <ProgressBar x:Name="Progress" Width="180" Height="12" IsIndeterminate="True"
                             Visibility="Collapsed" DockPanel.Dock="Right" />
                <TextBlock x:Name="TxtStatus" Text="준비" Foreground="White" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
