<Window x:Class="RubberBandRouting.Viewer.GroupPatternViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="그룹배관(수평/수직 다발) 3D 뷰어" Width="1300" Height="800" MinWidth="900" MinHeight="550"
        Icon="app_icon.ico"
        WindowStartupLocation="CenterOwner" Background="#172033">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="280"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Filter & Bundle List Panel -->
        <Border Grid.Column="0" Background="#263449" BorderBrush="#43536C" BorderThickness="0,0,1,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Filters -->
                    <RowDefinition Height="*"/>    <!-- Bundle List -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="필터 설정" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

                    <TextBlock Text="장비 (Equipment)" Foreground="#A5B4FC" FontSize="11" Margin="0,4,0,2"/>
                    <ComboBox x:Name="CmbEquipment" Height="26" SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock Text="유틸리티 그룹 (Utility Group)" Foreground="#A5B4FC" FontSize="11" Margin="0,8,0,2"/>
                    <ComboBox x:Name="CmbUtilityGroup" Height="26" SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock x:Name="TxtStatus" Text="장비와 유틸리티 그룹을 선택하세요." Foreground="#94A3B8" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="그룹배관 목록" Foreground="White" FontWeight="Bold" Margin="0,4,0,4"/>
                    <ListBox x:Name="LstBundles" Grid.Row="1" SelectionChanged="LstBundles_SelectionChanged"
                             Background="#2E3C53" Foreground="White" BorderBrush="#4B5F7B" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#3A4862" BorderThickness="0,0,0,1" Padding="2,6">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="14" Height="14" Fill="{Binding ColorBrush}" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding ShortId}" FontWeight="SemiBold" Foreground="#7CD4FF" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding Utility, StringFormat=' [{0}]'}" FontWeight="SemiBold" Foreground="#A5B4FC" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            <Border Background="{Binding AxisBadgeBg}" CornerRadius="3" Padding="5,1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding AxisBadge}" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SummaryText}" FontSize="10" Foreground="#DDE7F5" Margin="20,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <!-- Grid Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#43536C"/>

        <!-- Right 3D Viewport -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <helix:HelixViewport3D x:Name="Viewport3D" Background="#0B1020" ShowCoordinateSystem="True" ZoomExtentsWhenLoaded="False">
                    <helix:HelixViewport3D.DefaultCamera>
                        <PerspectiveCamera Position="8000,8000,6000" LookDirection="-8000,-8000,-6000" UpDirection="0,0,1" FieldOfView="45"/>
                    </helix:HelixViewport3D.DefaultCamera>
                    <helix:DefaultLights/>
                    <helix:GridLinesVisual3D Width="30000" Length="30000" MinorDistance="1000" MajorDistance="5000" Normal="0,0,1" Thickness="1" Fill="#334155"/>
                </helix:HelixViewport3D>

                <!-- Legend Overlay -->
                <Border Background="#A0172033" CornerRadius="4" Padding="8" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="범례" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="16" Height="10" Fill="#94A3B8" Margin="0,0,6,0"/>
                            <TextBlock Text="전체 유틸리티배관 (배경)" Foreground="White" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="16" Height="10" Fill="#FACC15" Margin="0,0,6,0"/>
                            <TextBlock Text="그룹배관 다발 (색상=그룹, 목록에서 선택시 강조)" Foreground="White" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="⬌ 수평 / ⬍ 수직 / ◇ 혼합" Foreground="#FDE68A" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Info Bar -->
            <Border Grid.Row="1" Background="#202B42" BorderBrush="#3A4862" BorderThickness="0,1,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="선택된 그룹: " Foreground="#DDE7F5" FontSize="12"/>
                        <TextBlock x:Name="TxtSelectedGroup" Text="선택 없음" Foreground="#7CD4FF" FontWeight="Bold" FontSize="12" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Button x:Name="BtnFitCamera" Grid.Column="1" Content="⤢ 전체보기 (Camera Fit)" Padding="10,4" Click="BtnFitCamera_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
