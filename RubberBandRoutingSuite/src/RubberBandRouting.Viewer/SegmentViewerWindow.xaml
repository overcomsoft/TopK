<Window x:Class="RubberBandRouting.Viewer.SegmentViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="기존설계경로 삼분할(Start/Trunk/End) 3D 뷰어" Width="1200" Height="750" MinWidth="800" MinHeight="500"
        Icon="app_icon.ico"
        WindowStartupLocation="CenterOwner" Background="#172033">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="250"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Filter & List Panel -->
        <Border Grid.Column="0" Background="#263449" BorderBrush="#43536C" BorderThickness="0,0,1,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Filters -->
                    <RowDefinition Height="2*"/>   <!-- Path List -->
                    <RowDefinition Height="1.5*"/> <!-- Clicked Attributes -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="필터 설정" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    
                    <TextBlock Text="장비 (Equipment)" Foreground="#A5B4FC" FontSize="11" Margin="0,4,0,2"/>
                    <ComboBox x:Name="CmbEquipment" Height="26" SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock Text="유틸리티 그룹 (Utility Group)" Foreground="#A5B4FC" FontSize="11" Margin="0,8,0,2"/>
                    <ComboBox x:Name="CmbUtilityGroup" Height="26" SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock Text="유틸리티 (Utility)" Foreground="#A5B4FC" FontSize="11" Margin="0,8,0,2"/>
                    <ComboBox x:Name="CmbUtility" Height="26" SelectionChanged="Filter_SelectionChanged"/>
                    
                    <Button x:Name="BtnResetFilters" Content="필터 초기화" Height="26" Margin="0,10,0,0" Click="BtnResetFilters_Click"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="배관 경로 목록" Foreground="White" FontWeight="Bold" Margin="0,4,0,4"/>
                    <ListBox x:Name="LstPaths" Grid.Row="1" SelectionChanged="LstPaths_SelectionChanged" 
                             Background="#2E3C53" Foreground="White" BorderBrush="#4B5F7B" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#7CD4FF"/>
                                    <TextBlock Text="{Binding DetailText}" FontSize="10" Foreground="#DDE7F5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- TabControl for Attributes and Sequential Path Details -->
                <TabControl Grid.Row="2" Margin="0,10,0,0" Background="#1E293B" BorderBrush="#334155">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="선택 객체 속성" Background="#2E3C53">
                        <Border Background="#1B2636" BorderBrush="#3A4862" BorderThickness="1" CornerRadius="0,0,4,4" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PnlAttributes">
                                    <TextBlock Text="3D 뷰의 배관/피팅을 클릭하세요." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </TabItem>
                    <TabItem Header="경로 상세 목록" Background="#2E3C53">
                        <Border Background="#1B2636" BorderBrush="#3A4862" BorderThickness="1" CornerRadius="0,0,4,4" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TxtPathInfoTitle" Grid.Row="0" Text="선택된 경로가 없습니다." Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <ListView x:Name="LvwPathSegments" Grid.Row="1" Background="#F1F5F9" Foreground="Black" BorderThickness="0" FontSize="11" 
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto" SelectionChanged="LvwPathSegments_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="순번" Width="35" DisplayMemberBinding="{Binding Seq}"/>
                                            <GridViewColumn Header="객체타입" Width="85" DisplayMemberBinding="{Binding TypeName}"/>
                                            <GridViewColumn Header="길이/각도" Width="80" DisplayMemberBinding="{Binding LengthOrAngle}"/>
                                            <GridViewColumn Header="크기" Width="80" DisplayMemberBinding="{Binding SizeText}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- Grid Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#43536C"/>

        <!-- Right 3D Viewport & Info Panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 3D Viewport & 2D Cross Sections Layout -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Main 3D View -->
                <Grid Grid.Column="0">
                    <helix:HelixViewport3D x:Name="Viewport3D" Background="#0B1020" ShowCoordinateSystem="True" ZoomExtentsWhenLoaded="False"
                                           PreviewMouseLeftButtonDown="Viewport3D_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Viewport3D_PreviewMouseLeftButtonUp">
                        <helix:HelixViewport3D.DefaultCamera>
                            <PerspectiveCamera Position="8000,8000,6000" LookDirection="-8000,-8000,-6000" UpDirection="0,0,1" FieldOfView="45"/>
                        </helix:HelixViewport3D.DefaultCamera>
                        <helix:DefaultLights/>
                        <helix:GridLinesVisual3D Width="30000" Length="30000" MinorDistance="1000" MajorDistance="5000" Normal="0,0,1" Thickness="1" Fill="#334155"/>
                    </helix:HelixViewport3D>

                    <!-- Legend Overlay -->
                    <Border Background="#A0172033" CornerRadius="4" Padding="8" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="구간 범례" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Rectangle Width="16" Height="10" Fill="OrangeRed" Margin="0,0,6,0"/>
                                <TextBlock Text="Start Stub (시작 인입부)" Foreground="White" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Rectangle Width="16" Height="10" Fill="LimeGreen" Margin="0,0,6,0"/>
                                <TextBlock Text="Middle Trunk (중앙 본선)" Foreground="White" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Rectangle Width="16" Height="10" Fill="Cyan" Margin="0,0,6,0"/>
                                <TextBlock Text="End Stub (종단 도출부)" Foreground="White" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#263449"/>

                <!-- Right Cross Sections Grid -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <!-- Top-Right: XY Cross Section (Horizontal) -->
                    <Grid Grid.Row="0">
                        <helix:HelixViewport3D x:Name="ViewportXY" Background="#0A0E1A" ShowCoordinateSystem="False" ZoomExtentsWhenLoaded="False" IsRotationEnabled="False">
                            <helix:HelixViewport3D.DefaultCamera>
                                <OrthographicCamera Position="0,0,100000" LookDirection="0,0,-1" UpDirection="0,1,0" Width="30000"/>
                            </helix:HelixViewport3D.DefaultCamera>
                            <helix:DefaultLights/>
                        </helix:HelixViewport3D>
                        <Border Background="#C0111827" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5">
                            <TextBlock Text="수평(XY면) 단면도" Foreground="#93C5FD" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <!-- Row Splitter -->
                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#263449"/>

                    <!-- Bottom-Right: Z Cross Section (Vertical) -->
                    <Grid Grid.Row="2">
                        <helix:HelixViewport3D x:Name="ViewportZ" Background="#0A0E1A" ShowCoordinateSystem="False" ZoomExtentsWhenLoaded="False" IsRotationEnabled="False">
                            <helix:HelixViewport3D.DefaultCamera>
                                <OrthographicCamera Position="0,100000,0" LookDirection="0,-1,0" UpDirection="0,0,1" Width="15000"/>
                            </helix:HelixViewport3D.DefaultCamera>
                            <helix:DefaultLights/>
                        </helix:HelixViewport3D>
                        <Border Background="#C0111827" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5">
                            <TextBlock Text="수직(Z면) 단면도 (CR/AF/CSF/FSF)" Foreground="#FCA5A5" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Bottom Info Bar -->
            <Border Grid.Row="1" Background="#202B42" BorderBrush="#3A4862" BorderThickness="0,1,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="선택된 배관 GUID: " Foreground="#DDE7F5" FontSize="12"/>
                        <TextBlock x:Name="TxtSelectedGuid" Text="선택 없음" Foreground="#7CD4FF" FontWeight="Bold" FontSize="12" Margin="5,0,0,0"/>
                        <Separator Width="2" Margin="15,0" Background="#3A4862"/>
                        <TextBlock Text="Start Stub: " Foreground="#DDE7F5" FontSize="12"/>
                        <TextBlock x:Name="TxtStartLen" Text="0 mm" Foreground="White" FontWeight="Bold" FontSize="12" Margin="5,0,15,0"/>
                        <TextBlock Text="Middle Trunk: " Foreground="#DDE7F5" FontSize="12"/>
                        <TextBlock x:Name="TxtTrunkLen" Text="0 mm" Foreground="White" FontWeight="Bold" FontSize="12" Margin="5,0,15,0"/>
                        <TextBlock Text="End Stub: " Foreground="#DDE7F5" FontSize="12"/>
                        <TextBlock x:Name="TxtEndLen" Text="0 mm" Foreground="White" FontWeight="Bold" FontSize="12" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Button x:Name="BtnFitCamera" Grid.Column="1" Content="⤢ 전체보기 (Camera Fit)" Padding="10,4" Click="BtnFitCamera_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
