<Window x:Class="RubberBandRouting.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="RubberBand Routing 3D Viewer - PostgreSQL PoC Auto Routing" Width="1500" Height="900"
        WindowStartupLocation="CenterScreen" Background="#172033">
    <Window.Resources>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#202B42" BorderBrush="#3A4862" BorderThickness="0,0,0,1" Padding="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="DB:" Foreground="#DDE7F5" VerticalAlignment="Center" Margin="4,0,2,0"/>
                <TextBox x:Name="TxtHost" Text="localhost" Width="90" Margin="2" VerticalContentAlignment="Center"/>
                <TextBox x:Name="TxtPort" Text="5432" Width="50" Margin="2" VerticalContentAlignment="Center"/>
                <TextBox x:Name="TxtUser" Text="postgres" Width="76" Margin="2" VerticalContentAlignment="Center"/>
                <PasswordBox x:Name="TxtPassword" Width="76" Margin="2" VerticalContentAlignment="Center"/>
                <TextBox x:Name="TxtDatabase" Text="DDW_AI_DB" Width="110" Margin="2" VerticalContentAlignment="Center"/>
                <TextBlock Text="프로젝트:" Foreground="#DDE7F5" VerticalAlignment="Center" Margin="10,0,2,0"/>
                <ComboBox x:Name="CmbProjects" Width="260" Margin="2" DisplayMemberPath="DisplayName"/>
                <Button x:Name="BtnLoadProjects" Content="↻ 로드" Width="70" Margin="8,2,4,2" Click="BtnLoadProjects_Click"/>
                <Button x:Name="BtnLoadScene" Content="기본설계" Width="76" Margin="4,2" Click="BtnLoadScene_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="306" MinWidth="240"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="360" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#263449" BorderBrush="#43536C" BorderThickness="0,0,1,0" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- ① 유틸리티 그룹 -->
                        <RowDefinition Height="Auto"/> <!-- ② 유틸리티 -->
                        <RowDefinition Height="Auto"/> <!-- ④ 라우팅 설정 -->
                        <RowDefinition Height="*"/>    <!-- ③ 개별 PoC -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#40516B" BorderThickness="1" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="① 유틸리티 그룹" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbUtilityGroups" Height="26" SelectionChanged="CmbUtilityGroups_SelectionChanged"/>
                            <Button x:Name="BtnRouteSelectedGroup" Content="▶ 이 그룹 전체 라우팅" Height="30" Margin="0,6,0,0" Background="#416B9E" Foreground="White" Click="BtnRouteGroup_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="#40516B" BorderThickness="1" Padding="6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="② 유틸리티" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ListBox x:Name="ListUtilities" Grid.Row="1" Height="100" SelectionChanged="ListUtilities_SelectionChanged" Background="#2E3C53" Foreground="White" BorderBrush="#4B5F7B"/>
                            <Button x:Name="BtnRouteUtility" Grid.Row="2" Content="▶ 이 유틸리티 전체 라우팅" Margin="0,6,0,0" Click="BtnRouteUtility_Click"/>
                            <Button x:Name="BtnClearRoutes" Grid.Row="3" Content="♜ 자동설계 경로 삭제" Margin="0,6,0,0" Click="BtnClearRoutes_Click"/>
                            <Button x:Name="BtnShowExistingRoutes" Grid.Row="4" Content="◎ PostgresDB 기존경로 표시" Margin="0,6,0,0" Background="#5B6478" Foreground="White" Click="BtnShowExistingRoutes_Click"/>
                            <Button x:Name="BtnCompareRoutes" Grid.Row="5" Content="⇄ 기존경로와 비교" Margin="0,6,0,0" Background="#3B7A9E" Foreground="White" Click="BtnCompareRoutes_Click"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="#40516B" BorderThickness="1" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="④ 라우팅 설정" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="안전 마진(mm)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtSafetyMargin" Text="50" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,2">
                                    <TextBlock Text="트레이 폭(mm)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtTrayWidth" Text="600" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>

                                <!-- Row 1 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="트레이 높이(mm)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtTrayHeight" Text="100" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,2">
                                    <TextBlock Text="파이프 피치(mm)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtPipePitch" Text="100" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>

                                <!-- Row 2 -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="파이프 수(가닥)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtPipeCount" Text="1" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,2">
                                    <TextBlock Text="곡률 반경 배수(D)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtBendRadiusFactor" Text="3.0" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>

                                <!-- Row 3 -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,2">
                                    <TextBlock Text="최대 수직 꺾임" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtMaxVerticalBends" Text="99" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,2">
                                    <TextBlock Text="허용 오차(mm)" Foreground="#DDE7F5" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="TxtSnapTolerance" Text="100" Height="22" VerticalContentAlignment="Center" TextChanged="SettingTextBox_TextChanged" LostFocus="SettingTextBox_LostFocus" KeyDown="SettingTextBox_KeyDown"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" BorderBrush="#40516B" BorderThickness="1" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="③ 개별 PoC (선택 = 3D 강조)" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <DataGrid x:Name="GridTasks" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridTasks_SelectionChanged"
                                      Background="#253349" Foreground="White" BorderBrush="#40516B" GridLinesVisibility="None"
                                      HeadersVisibility="Column" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="38"/>
                                    <DataGridTextColumn Header="유틸" Binding="{Binding Utility}" Width="58"/>
                                    <DataGridTextColumn Header="시작PoC" Binding="{Binding SourceName}" Width="94"/>
                                    <DataGridTextColumn Header="종단PoC" Binding="{Binding TargetName}" Width="94"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#43536C"/>

            <Grid Grid.Column="2">
                <helix:HelixViewport3D x:Name="Viewport" Background="#0B1020" ShowCoordinateSystem="True" ZoomExtentsWhenLoaded="False"
                                       PreviewMouseLeftButtonDown="Viewport_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Viewport_PreviewMouseLeftButtonUp">
                    <helix:HelixViewport3D.DefaultCamera>
                        <PerspectiveCamera Position="18000,18000,12000" LookDirection="-18000,-18000,-12000" UpDirection="0,0,1" FieldOfView="45"/>
                    </helix:HelixViewport3D.DefaultCamera>
                    <helix:DefaultLights/>
                    <helix:GridLinesVisual3D Width="50000" Length="50000" MinorDistance="1000" MajorDistance="5000" Normal="0,0,1" Thickness="1" Fill="#334155"/>
                </helix:HelixViewport3D>
                
                <!-- 특징점 범례 (Legend) -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,8,0,0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="10,8" Opacity="0.95">
                    <StackPanel>
                        <TextBlock Text="특징점 범례 (Legend)" Foreground="#DDE7F5" FontWeight="Bold" FontSize="11" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="OrangeRed" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                            <TextBlock Text="시작스텁 (StartStub)" Foreground="#E2E8F0" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="Magenta" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                            <TextBlock Text="꺾임 (Bend)" Foreground="#E2E8F0" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="Cyan" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                            <TextBlock Text="고도변경 (ElevationChange)" Foreground="#E2E8F0" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="MediumPurple" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                            <TextBlock Text="트렁크 (TrunkGuide)" Foreground="#E2E8F0" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Rectangle Width="12" Height="12" Fill="LimeGreen" RadiusX="2" RadiusY="2" Margin="0,0,6,0"/>
                            <TextBlock Text="종단접근 (EndApproach)" Foreground="#E2E8F0" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0" Background="#172033" CornerRadius="4" Padding="10,6" Opacity="0.92">
                    <StackPanel>
                        <TextBlock x:Name="TxtFps" Text="FPS 0.0" Foreground="#7CFF8A" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                        <TextBlock x:Name="TxtVisibleObjects" Text="렌더 0 obj" Foreground="#7CFF8A" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#43536C"/>

            <Border Grid.Column="4" Background="#263449" BorderBrush="#43536C" BorderThickness="1,0,0,0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="140"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="310" MinHeight="120"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="자동설계 결과 경로" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <CheckBox x:Name="ChkEnableDebugLog" Content="디버그로그 생성" IsChecked="True" Foreground="#A7C7FF" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="관리형 엔진 사용 시 세그먼트 구간별 A* 탐색 디버그 정보를 파일로 기록합니다."/>
                            <Button x:Name="BtnReplayDebug" Content="디버그리플레이" Padding="6,2" Background="#1E3A8A" BorderBrush="#3B82F6" Foreground="White" Click="BtnReplayDebug_Click" ToolTip="선택한 경로를 디버그 로그와 함께 다시 라우팅(재실행)하고 로그 파일을 메모장으로 즉시 엽니다."/>
                            <Button x:Name="BtnDeleteSelectedRoute" Content="자동경로삭제" Margin="6,0,0,0" Padding="6,2" Click="BtnDeleteSelectedRoute_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <DataGrid x:Name="GridResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridResults_SelectionChanged"
                              Background="#253349" Foreground="White" BorderBrush="#40516B" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="{Binding RouteRowBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FACC15"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="34"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="58"/>
                            <DataGridTextColumn Header="실패사유" Binding="{Binding FailureReason}" Width="90"/>
                            <DataGridTextColumn Header="그룹" Binding="{Binding Group}" Width="62"/>
                            <DataGridTextColumn Header="유틸" Binding="{Binding Utility}" Width="56"/>
                            <DataGridTextColumn Header="시작PoC" Binding="{Binding StartPoC}" Width="82"/>
                            <DataGridTextColumn Header="종단PoC" Binding="{Binding EndPoC}" Width="82"/>
                            <DataGridTextColumn Header="길이" Binding="{Binding LengthText}" Width="70"/>
                            <DataGridTextColumn Header="꺽임수량" Binding="{Binding VerticalBends}" Width="70"/>
                            <DataGridTextColumn Header="라우팅시간(ms)" Binding="{Binding ElapsedText}" Width="96"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#43536C"/>
                    <TabControl Grid.Row="3" Margin="0,10,0,0" Background="#263449" Foreground="White">
                        <TabItem Header="분석결과">
                            <DataGrid x:Name="GridAnalysis" AutoGenerateColumns="False" IsReadOnly="True" Background="#253349" Foreground="White" BorderBrush="#40516B" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="항목" Binding="{Binding Name}" Width="100"/>
                                    <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="단계별 경로">
                            <DataGrid x:Name="GridStepDetails" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridStepDetails_SelectionChanged" Background="#253349" Foreground="White" BorderBrush="#40516B" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="36"/>
                                    <DataGridTextColumn Header="구간" Binding="{Binding SegmentType}" Width="70"/>
                                    <DataGridTextColumn Header="시작" Binding="{Binding Start}" Width="96"/>
                                    <DataGridTextColumn Header="끝" Binding="{Binding End}" Width="96"/>
                                    <DataGridTextColumn Header="방향" Binding="{Binding Direction}" Width="54"/>
                                    <DataGridTextColumn Header="길이" Binding="{Binding LengthText}" Width="72"/>
                                    <DataGridTextColumn Header="꺾임/사유" Binding="{Binding Reason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="세그먼트 상세">
                            <DataGrid x:Name="GridSegmentDetails" AutoGenerateColumns="False" IsReadOnly="True" Background="#253349" Foreground="White" BorderBrush="#40516B" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="36"/>
                                    <DataGridTextColumn Header="시작" Binding="{Binding Start}" Width="96"/>
                                    <DataGridTextColumn Header="끝" Binding="{Binding End}" Width="96"/>
                                    <DataGridTextColumn Header="길이" Binding="{Binding LengthText}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="설계오류리스트">
                            <DataGrid x:Name="GridErrorList" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridErrorList_SelectionChanged" Background="#253349" Foreground="White" BorderBrush="#40516B" RowBackground="#253349" AlternatingRowBackground="#2B3B54">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="36"/>
                                    <DataGridTextColumn Header="오류 유형" Binding="{Binding ErrorType}" Width="120"/>
                                    <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#172033" BorderBrush="#43536C" BorderThickness="0,1,0,0" Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="레이어 표시:" Foreground="#DDE7F5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CheckBox x:Name="TglArea" Content="공간" IsChecked="True" Foreground="White" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglObstacles" Content="장애물" IsChecked="True" Foreground="White" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglEquipment" Content="장비" IsChecked="True" Foreground="#FFB85A" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglDucts" Content="덕트/레터럴" IsChecked="True" Foreground="#7EE2AE" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglPocs" Content="PoC 마커" IsChecked="True" Foreground="#FF6767" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglRoutes" Content="자동경로" IsChecked="True" Foreground="White" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglFeaturePoints" Content="특징점" IsChecked="True" Foreground="#FF4DFF" Margin="0,0,8,0" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <CheckBox x:Name="TglExistingRoutes" Content="기존경로" IsChecked="True" Foreground="#FFB347" Checked="LayerToggle_Changed" Unchecked="LayerToggle_Changed"/>
                    <Separator Margin="6,0" Width="1"/>
                    <CheckBox x:Name="ChkUseNativeEngine" Content="네이티브 C++ 엔진" Foreground="#7CD4FF" Margin="10,0,0,0"
                              Checked="ChkUseNativeEngine_Changed" Unchecked="ChkUseNativeEngine_Changed"
                              ToolTip="build_msvc.bat로 빌드한 RubberBandRouting.Native.dll이 있어야 사용 가능합니다. 없으면 관리형(C#) 엔진으로 자동 대체됩니다."/>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" Grid.Column="1" Text="준비됨" Foreground="#A7C7FF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button Grid.Column="2" Content="카메라 초기화" Width="110" Height="24" Click="BtnResetCamera_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>











