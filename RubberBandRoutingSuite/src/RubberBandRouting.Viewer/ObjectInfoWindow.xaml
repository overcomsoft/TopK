<Window x:Class="RubberBandRouting.Viewer.ObjectInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="객체 정보 (Object Properties)" Width="380" Height="450"
        WindowStartupLocation="Manual" Background="#111827" Foreground="White"
        Topmost="True" ResizeMode="CanResize" ShowInTaskbar="False" BorderBrush="#374151" BorderThickness="1">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="TxtCategory" Text="객체 분류" Foreground="#60A5FA" FontSize="12" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBlock x:Name="TxtName" Text="객체 이름 / 식별자" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
            <Border BorderBrush="#374151" BorderThickness="0,0,0,1" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Properties Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <Grid x:Name="GridProps">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Dynamically populated programmatically -->
            </Grid>
        </ScrollViewer>

        <!-- Footer / Action -->
        <Button Grid.Row="2" Content="닫기 (Close)" Click="BtnClose_Click" 
                Background="#374151" Foreground="White" BorderThickness="0" Height="32" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
