<Window x:Class="GroupPatternViewer.GenerateSegmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="그룹 세그먼트 생성 (ExtractGroupSegments.py)" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" Background="#FF252526" Foreground="#FFF1F1F1"
        BorderBrush="#FF3F3F46" BorderThickness="1">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF505054"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF2D2D30"/>
                                <Setter Property="Foreground" Value="#FF7F7F7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="데이터베이스 연결 (자동 설정됨)" Foreground="#FF007ACC" BorderBrush="#FF3F3F46" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Host:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtHost" Grid.Row="0" Grid.Column="1" Margin="0,0,10,5" IsReadOnly="True"/>

                <TextBlock Text="Port:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtPort" Grid.Row="0" Grid.Column="3" Margin="0,0,0,5" IsReadOnly="True"/>

                <TextBlock Text="DB:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtDb" Grid.Row="1" Grid.Column="1" Margin="0,0,10,5" IsReadOnly="True"/>

                <TextBlock Text="User:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtUser" Grid.Row="1" Grid.Column="3" Margin="0,0,0,5" IsReadOnly="True"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="추출 실행 로그" Foreground="#FF007ACC" BorderBrush="#FF3F3F46" Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="TxtOutput" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" Background="#FF1E1E1E" Foreground="#FFD4D4D4" BorderThickness="0" Margin="2"/>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnRun" Content="추출 시작" Width="100" Margin="0,0,10,0" Click="BtnRun_Click" Background="#FF007ACC"/>
            <Button x:Name="BtnClose" Content="닫기" Width="80" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
