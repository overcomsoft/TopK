<Window x:Class="GroupPatternViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:GroupPatternViewer"
        Title="그룹배관 패턴 분석 3D 시각화 뷰어"
        Width="1350" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#FF252526"
        Foreground="#FFF1F1F1"
        Icon="app_icon.ico">

    <Window.Resources>
        <local:UtilityGroupToBrushConverter x:Key="UtilColorConverter"/>
        <!-- ScrollViewer style for Dark Theme -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="BorderBrush" Value="#333337"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="RowBackground" Value="#FF1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#FF252526"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF3F3F46"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FF3F3F46"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF505054"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF2D2D30"/>
                                <Setter Property="Foreground" Value="#FF7F7F7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 DB 접속 정보 바 -->
        <Border Grid.Row="0" Background="#FF1E1E1E" BorderThickness="0,0,0,1" BorderBrush="#FF3F3F46" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Title -->
                    <ColumnDefinition Width="Auto"/> <!-- Host Lbl -->
                    <ColumnDefinition Width="100"/>  <!-- Host Txt -->
                    <ColumnDefinition Width="Auto"/> <!-- Port Lbl -->
                    <ColumnDefinition Width="50"/>   <!-- Port Txt -->
                    <ColumnDefinition Width="Auto"/> <!-- DB Lbl -->
                    <ColumnDefinition Width="100"/>  <!-- DB Txt -->
                    <ColumnDefinition Width="Auto"/> <!-- User Lbl -->
                    <ColumnDefinition Width="80"/>   <!-- User Txt -->
                    <ColumnDefinition Width="Auto"/> <!-- Pwd Lbl -->
                    <ColumnDefinition Width="80"/>   <!-- Pwd Txt -->
                    <ColumnDefinition Width="Auto"/> <!-- Connect Btn -->
                    <ColumnDefinition Width="Auto"/> <!-- Project Lbl -->
                    <ColumnDefinition Width="280"/>  <!-- Project Cmb -->
                    <ColumnDefinition Width="*"/>     <!-- Status & Spacer -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="GroupPattern 3D 시각화" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#FF007ACC" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="1" Text="Host:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <TextBox x:Name="TxtHost" Grid.Column="2" Height="22" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF555555" Padding="4,1" FontSize="11" TextChanged="DbField_Changed"/>

                <TextBlock Grid.Column="3" Text="Port:" VerticalAlignment="Center" Margin="8,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <TextBox x:Name="TxtPort" Grid.Column="4" Height="22" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF555555" Padding="4,1" FontSize="11" TextChanged="DbField_Changed"/>

                <TextBlock Grid.Column="5" Text="Database:" VerticalAlignment="Center" Margin="8,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <TextBox x:Name="TxtDbname" Grid.Column="6" Height="22" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF555555" Padding="4,1" FontSize="11" TextChanged="DbField_Changed"/>

                <TextBlock Grid.Column="7" Text="User:" VerticalAlignment="Center" Margin="8,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <TextBox x:Name="TxtUser" Grid.Column="8" Height="22" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF555555" Padding="4,1" FontSize="11" TextChanged="DbField_Changed"/>

                <TextBlock Grid.Column="9" Text="Password:" VerticalAlignment="Center" Margin="8,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <PasswordBox x:Name="TxtPassword" Grid.Column="10" Height="22" Background="#FF2D2D30" Foreground="White" BorderBrush="#FF555555" Padding="4,1" FontSize="11" PasswordChanged="DbField_Changed"/>

                <Button x:Name="BtnConnect" Grid.Column="11" Content="접속" Margin="10,0,0,0" Padding="12,2" Height="24" Click="BtnConnect_Click" Background="#FF3E3E42" FontWeight="SemiBold"/>
                
                <TextBlock Grid.Column="12" Text="프로젝트:" VerticalAlignment="Center" Margin="15,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <ComboBox x:Name="CmbProject" Grid.Column="13" Height="22" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderBrush="#FF555555" DisplayMemberPath="Display" SelectionChanged="CmbProject_SelectionChanged" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="14" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock x:Name="TxtConnStatus" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="● 미접속" Foreground="#FFB00020"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 프레임 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 제어판 -->
            <Grid Grid.Column="0" Background="#FF2D2D30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 검색 및 필터 옵션 -->
                <Border Grid.Row="0" Background="#FF252526" Padding="12" Margin="10" CornerRadius="4" BorderThickness="1" BorderBrush="#FF3F3F46">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="그룹명 검색:" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="TxtSearchGroup" Grid.Column="1" Height="24" Background="#FF1E1E1E" Foreground="White" BorderBrush="#FF555555" Padding="4,2" KeyUp="FilterFields_Changed"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="유틸리티 그룹:" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CmbUtilityGroup" Grid.Column="1" Height="24" Background="White" Foreground="Black" BorderBrush="#FF555555" SelectionChanged="CmbUtilityGroup_SelectionChanged">
                                <ComboBoxItem Content="전체" IsSelected="True" Foreground="Black"/>
                            </ComboBox>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="유틸리티:" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox x:Name="CmbUtility" Grid.Column="1" Height="24" Background="White" Foreground="Black" BorderBrush="#FF555555" SelectionChanged="FilterFields_Changed">
                                <ComboBoxItem Content="전체" IsSelected="True" Foreground="Black"/>
                            </ComboBox>
                            <Button x:Name="BtnRefresh" Grid.Column="3" Content="새로고침" Padding="10,2" Click="BtnRefresh_Click" Height="24" IsEnabled="False"/>
                        </Grid>
                    </StackPanel>
                </Border>


                <!-- 패턴 그룹 목록 -->
                <Grid Grid.Row="1" Margin="10,0,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="TxtGroupCount" Text="검색된 그룹: 0개" FontWeight="SemiBold" Margin="2,0,0,6"/>
                    <DataGrid x:Name="DgGroups" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgGroups_SelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="{Binding UtilityGroup, Converter={StaticResource UtilColorConverter}}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF007ACC"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="그룹명" Binding="{Binding TagGroupNm}" Width="1.1*" MinWidth="80"/>
                            <DataGridTextColumn Header="그룹" Binding="{Binding UtilityGroup}" Width="0.9*" MinWidth="70"/>
                            <DataGridTextColumn Header="유틸리티" Binding="{Binding Utility}" Width="1*" MinWidth="70"/>
                            <DataGridTextColumn Header="배관수" Binding="{Binding NMembers}" Width="0.7*" MinWidth="50"/>
                            <DataGridTextColumn Header="패턴" Binding="{Binding PatternSeq}" Width="0.8*" MinWidth="60"/>
                            <DataGridTextColumn Header="Trunk Z" Binding="{Binding TrunkZ, StringFormat={}{0:N0}}" Width="0.9*" MinWidth="60"/>
                            <DataGridTextColumn Header="대표이격" Binding="{Binding PitchMm, StringFormat={}{0:N0}}" Width="0.9*" MinWidth="60"/>
                            <DataGridTextColumn Header="접속 PoC 목록" Binding="{Binding PocList}" Width="1.5*" MinWidth="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- 하단 상세정보 및 3D 토글 옵션 -->
                <Border Grid.Row="2" Background="#FF1E1E1E" BorderThickness="0,1,0,0" BorderBrush="#FF3F3F46" Padding="12">
                    <StackPanel>
                        <TextBlock Text="시각화 옵션" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#FF007ACC"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ChkShowEquipment" Grid.Row="0" Grid.Column="0" Content="설비" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,2"/>
                            <CheckBox x:Name="ChkShowDucts" Grid.Row="0" Grid.Column="1" Content="덕트/레터럴" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,2"/>
                            <CheckBox x:Name="ChkShowObstacles" Grid.Row="0" Grid.Column="2" Content="장애물(나머지)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,2"/>
                            
                            <CheckBox x:Name="ChkShowBackgroundPipes" Grid.Row="1" Grid.Column="0" Content="기존배관" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,6,0,2"/>
                            <CheckBox x:Name="ChkShowPipes" Grid.Row="1" Grid.Column="1" Content="그룹배관" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,6,0,2"/>
                            <CheckBox x:Name="ChkShowBoxes" Grid.Row="1" Grid.Column="2" Content="구간 Box" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,6,0,2"/>
                            
                            <CheckBox x:Name="ChkShowGrid" Grid.Row="2" Grid.Column="0" Content="그리드" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,6,0,2"/>
                        </Grid>

                        
                        <TextBlock Text="선택된 그룹 정보" FontWeight="SemiBold" Margin="0,5,0,5" Foreground="#FF007ACC"/>
                        <Grid x:Name="GridSelectedInfo" Margin="0,0,0,5" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,2">
                                <Run Text="● 그룹: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedGroup" Text="-" FontWeight="SemiBold" Foreground="#FF52B3D9"/>
                                <Run Text=" | 유틸리티: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedUtil" Text="-" FontWeight="SemiBold" Foreground="#FF2ECC71"/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Margin="0,2">
                                <Run Text="● 패턴 ID: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedId" Text="-" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Grid.Row="2" Margin="0,2">
                                <Run Text="● 평균 유사도: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedSim" Text="-" FontWeight="SemiBold"/>
                                <Run Text=" | 꺾임수: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedBends" Text="-" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Grid.Row="3" Margin="0,2" TextWrapping="Wrap">
                                <Run Text="● 멤버 GUID: " Foreground="#FF888888"/>
                                <Run x:Name="TxtSelectedGuids" Text="-" FontSize="10" Foreground="#FFAAAAAA"/>
                            </TextBlock>
                        </Grid>
                        
                        <!-- 3D 클릭 배관 속성 패널 -->
                        <TextBlock Text="선택된 배관 속성 (3D 클릭)" FontWeight="SemiBold" Margin="0,12,0,5" Foreground="#FF007ACC"/>
                        <Grid x:Name="GridClickedPipeInfo" Margin="0,0,0,5" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,2">
                                <Run Text="● 유형: " Foreground="#FF888888"/>
                                <Run x:Name="TxtClickedType" Text="-" FontWeight="SemiBold" Foreground="#FFFFB900"/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Margin="0,2">
                                <Run Text="● GUID: " Foreground="#FF888888"/>
                                <Run x:Name="TxtClickedGuid" Text="-" FontSize="10" Foreground="#FFAAAAAA"/>
                            </TextBlock>
                            <TextBlock Grid.Row="2" Margin="0,2">
                                <Run Text="● 유틸리티: " Foreground="#FF888888"/>
                                <Run x:Name="TxtClickedUtil" Text="-" FontWeight="SemiBold" Foreground="#FF2ECC71"/>
                                <Run Text=" | 그룹: " Foreground="#FF888888"/>
                                <Run x:Name="TxtClickedGroup" Text="-" FontWeight="SemiBold" Foreground="#FF52B3D9"/>
                            </TextBlock>
                            <TextBlock Grid.Row="3" Margin="0,2">
                                <Run Text="● 관경: " Foreground="#FF888888"/>
                                <Run x:Name="TxtClickedSize" Text="-" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Grid>
                        <TextBlock x:Name="TxtClickedPipePlaceholder" Text="3D 뷰에서 배관을 클릭하면 상세 속성이 표시됩니다." Foreground="#FF888888" FontSize="11" Margin="5,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 분할 바 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF3F3F46"/>

            <!-- 우측 3D 뷰포트 -->
            <Grid Grid.Column="2" Background="#FF1E1E1E">
                <helix:HelixViewport3D x:Name="Viewport3D" 
                                       MouseDown="Viewport3D_MouseDown"
                                       ZoomExtentsWhenLoaded="False" 
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="True" 
                                       CoordinateSystemHorizontalPosition="Left"
                                       CoordinateSystemVerticalPosition="Bottom"
                                       TitleBackground="Transparent"
                                       Background="#FF1E1E1E">
                    <helix:HelixViewport3D.DefaultCamera>
                        <PerspectiveCamera Position="20000, 20000, 15000" LookDirection="-20000, -20000, -15000" UpDirection="0,0,1" FieldOfView="45"/>
                    </helix:HelixViewport3D.DefaultCamera>

                    <!-- 기본 조명 및 배경 그리드 -->
                    <helix:DefaultLights/>
                    
                    <helix:GridLinesVisual3D x:Name="GridLines" 
                                             Width="50000" 
                                             Length="50000" 
                                             MinorDistance="1000" 
                                             MajorDistance="5000" 
                                             Normal="0,0,1" 
                                             Thickness="2"
                                             Fill="#30CCCCCC"/>
                </helix:HelixViewport3D>

                <!-- 뷰포트 오버레이 컨트롤 버튼들 -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="15,15,50,15" Orientation="Horizontal">
                    <Button Content="뷰 초기화 (Zoom Extents)" Click="BtnZoomExtents_Click" Margin="0,0,8,0" FontWeight="SemiBold" Background="#FF007ACC"/>
                    <Button Content="3D 화면 비우기" Click="BtnClear3D_Click" FontWeight="SemiBold" Background="#FFC62828"/>
                </StackPanel>

                <!-- 로딩 마스크 -->
                <Grid x:Name="GridLoading" Background="#90000000" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="15" Background="#FF333333" Foreground="#FF007ACC"/>
                        <TextBlock Text="데이터 로딩 및 3D 생성 중..." HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
