<Window x:Class="GroupPatternViewer.GroupAnalysisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="선택 배관 패턴 분석 결과" Height="600" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#FF252526" Foreground="#FFF1F1F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 결과 헤더 -->
        <Border Grid.Row="0" x:Name="BorderResult" Padding="15" CornerRadius="8" Background="#FF333337">
            <TextBlock x:Name="TxtFinalVerdict" Text="분석 결과 로딩 중..." FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,5">
            <TextBlock Text="선택된 배관 수: " FontSize="14" Foreground="#FFCCCCCC"/>
            <TextBlock x:Name="TxtPipeCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#FFFFB900"/>
        </StackPanel>

        <!-- 지표 시각화 (대시보드 영역) -->
        <Border Grid.Row="2" Background="#FF1E1E1E" CornerRadius="8" Padding="20" Margin="0,5,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 형상 유사도 (Similarity) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="형상 유사도 (Shape Similarity)" Foreground="#FFE0E0E0" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock x:Name="TxtSimValue" Text="0% (기준: 70% 이상)" HorizontalAlignment="Right" Foreground="#FFAAAAAA" FontSize="13"/>
                    </Grid>
                    <Grid Height="12">
                        <ProgressBar x:Name="ProgSimilarity" Minimum="0" Maximum="100" Value="0" Background="#FF3E3E42" BorderThickness="0"/>
                    </Grid>
                </StackPanel>

                <!-- 간격 불균일도 (Pitch CV) -->
                <StackPanel Grid.Row="1" Margin="0,0,0,25">
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="간격 불균일도 (Pitch CV)" Foreground="#FFE0E0E0" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock x:Name="TxtCvValue" Text="0.00 (기준: 0.30 이하)" HorizontalAlignment="Right" Foreground="#FFAAAAAA" FontSize="13"/>
                    </Grid>
                    <Grid Height="12">
                        <ProgressBar x:Name="ProgCv" Minimum="0" Maximum="0.6" Value="0" Background="#FF3E3E42" BorderThickness="0"/>
                    </Grid>
                    <TextBlock Text="* 불균일도는 수치가 낮을수록 배관 간격이 일정함을 의미합니다." FontSize="11" Foreground="#FF888888" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- 속성 매칭 현황 (Utility & Bends) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="유틸리티 매칭: " Foreground="#FFAAAAAA" FontSize="14"/>
                        <TextBlock x:Name="TxtUtilStatus" Text="-" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="대표 꺾임 수: " Foreground="#FFAAAAAA" FontSize="14"/>
                        <TextBlock x:Name="TxtBendsStatus" Text="-" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 상세 로그 영역 -->
        <TextBlock Grid.Row="3" Text="상세 로그 메시지" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Border Grid.Row="4" Background="#FF1E1E1E" CornerRadius="5" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PanelMessages" Orientation="Vertical"/>
            </ScrollViewer>
        </Border>

        <!-- 하단 닫기 버튼 -->
        <Button Grid.Row="5" Content="확인" Width="100" Height="32" Margin="0,15,0,0" HorizontalAlignment="Center" Click="BtnClose_Click" Background="#FF007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="14">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
