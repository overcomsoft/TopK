<Window x:Class="AutoRouteFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:AutoRouteFinder"
        Title="AI 자동설계 특징점 연계 경로탐색 뷰어"
        Width="1400" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#FF252526"
        Foreground="#FFF1F1F1">

    <Window.Resources>
        <local:UtilityGroupToBrushConverter x:Key="UtilColorConverter"/>
        
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="RowBackground" Value="#FF1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#FF252526"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF3F3F46"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FF3F3F46"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF505054"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF2D2D30"/>
                                <Setter Property="Foreground" Value="#FF7F7F7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 컨트롤 바 -->
        <Border Grid.Row="0" Background="#FF1E1E1E" BorderThickness="0,0,0,1" BorderBrush="#FF3F3F46" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="AI AutoRouteFinder" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#FF007ACC" Margin="0,0,25,0"/>

                <TextBlock Grid.Column="1" Text="프로젝트 선택:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Foreground="#FFAAAAAA"/>
                <ComboBox x:Name="CmbProject" Grid.Column="2" Height="24" VerticalContentAlignment="Center" Background="White" Foreground="Black" BorderBrush="#FF555555" DisplayMemberPath="Display" SelectionChanged="CmbProject_SelectionChanged" Margin="0,0,15,0"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtConnStatus" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="● DB 로드 대기" Foreground="#FFFFB900" Margin="0,0,15,0"/>
                    <CheckBox x:Name="ChkUseFeatureProfile" Content="기존설계 특징점(Rack/Spine/Face) 연계 적용" Foreground="White" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="12" FontWeight="SemiBold"/>
                    <CheckBox x:Name="ChkUseTopKSimilarity" Content="유사설계 Top-K 회랑 연계" Foreground="White" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="12" FontWeight="SemiBold"/>
                    <Button x:Name="BtnRunRouting" Content="▶ 자동설계 실행" Padding="15,3" Click="BtnRunRouting_Click" Height="26" Background="#FF007ACC" Foreground="White" FontWeight="Bold"/>
                </StackPanel>

                <TextBlock x:Name="TxtStatus" Grid.Column="4" Text="대기 중..." Foreground="#FFAAAAAA" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- 메인 콘텐츠 영역 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 패널: 작업(Task) 목록 -->
            <Grid Grid.Column="0" Background="#FF2D2D30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF252526" Padding="12" Margin="10" CornerRadius="4" BorderThickness="1" BorderBrush="#FF3F3F46">
                    <StackPanel>
                        <TextBlock Text="설계 대상 작업 필터" Foreground="#FF007ACC" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- 유틸리티 그룹 콤보박스 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="유틸리티 그룹:" VerticalAlignment="Center" FontSize="11" Foreground="#FFAAAAAA"/>
                            <ComboBox x:Name="CmbUtilityGroup" Grid.Column="1" Height="24" VerticalContentAlignment="Center" SelectionChanged="CmbUtilityGroup_SelectionChanged"/>
                        </Grid>

                        <!-- 유틸리티 콤보박스 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="유틸리티:" VerticalAlignment="Center" FontSize="11" Foreground="#FFAAAAAA"/>
                            <ComboBox x:Name="CmbUtility" Grid.Column="1" Height="24" VerticalContentAlignment="Center" SelectionChanged="CmbUtility_SelectionChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="텍스트 검색:" VerticalAlignment="Center" FontSize="11" Foreground="#FFAAAAAA"/>
                            <TextBox x:Name="TxtSearchGroup" Grid.Column="1" Height="22" Background="#FF1E1E1E" Foreground="White" BorderBrush="#FF555555" Padding="4,1" KeyUp="FilterFields_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 작업 목록 데이터그리드 -->
                <Grid Grid.Row="1" Margin="10,0,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="TxtTaskCount" Text="대상 배관: 0개" FontWeight="SemiBold" Margin="2,0,0,6"/>
                    <DataGrid x:Name="DgTasks" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgTasks_SelectionChanged">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="{Binding Group, Converter={StaticResource UtilColorConverter}}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF007ACC"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="장비명" Binding="{Binding EquipmentTag}" Width="1.2*" MinWidth="90"/>
                            <DataGridTextColumn Header="유틸리티" Binding="{Binding Utility}" Width="1*" MinWidth="70"/>
                            <DataGridTextColumn Header="그룹" Binding="{Binding Group}" Width="0.8*" MinWidth="60"/>
                            <DataGridTextColumn Header="관경" Binding="{Binding DiameterMm, StringFormat={}{0:0}A}" Width="0.6*" MinWidth="40"/>
                            <DataGridTextColumn Header="출발 PoC" Binding="{Binding PocName}" Width="1.2*" MinWidth="90"/>
                            <DataGridTextColumn Header="종단 PoC" Binding="{Binding EndName}" Width="1.2*" MinWidth="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- 3D 뷰어 레이어 토글 -->
                <Border Grid.Row="2" Background="#FF1E1E1E" BorderThickness="0,1,0,0" BorderBrush="#FF3F3F46" Padding="12">
                    <StackPanel>
                        <TextBlock Text="3D 시각화 레이어 설정" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#FF007ACC"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ChkShowObstacles" Grid.Row="0" Grid.Column="0" Content="장애물(BIM)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowMainEquipment" Grid.Row="0" Grid.Column="1" Content="주설비(Main)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowSubEquipment" Grid.Row="1" Grid.Column="0" Content="부대장비(Sub)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowDuctsLaterals" Grid.Row="1" Grid.Column="1" Content="덕트/레터럴" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowExistingPipes" Grid.Row="2" Grid.Column="0" Content="사람의 기존설계" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowAutoPipes" Grid.Row="2" Grid.Column="1" Content="특징점 자동설계" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowSpines" Grid.Row="3" Grid.Column="0" Content="공용 척추선(Spine)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                            <CheckBox x:Name="ChkShowTopKPipes" Grid.Row="3" Grid.Column="1" Content="유사설계(Top-K)" Foreground="White" IsChecked="True" Checked="Option_Checked" Unchecked="Option_Checked" Margin="0,3"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 분할 바 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF3F3F46"/>

            <!-- 중앙: 3D 뷰포트 -->
            <Grid Grid.Column="2" Background="#FF1E1E1E">
                <helix:HelixViewport3D x:Name="Viewport3D" 
                                       ZoomExtentsWhenLoaded="False" 
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="True" 
                                       CoordinateSystemHorizontalPosition="Left"
                                       CoordinateSystemVerticalPosition="Bottom"
                                       Background="#FF1E1E1E">
                    <helix:HelixViewport3D.DefaultCamera>
                        <PerspectiveCamera Position="20000, 20000, 15000" LookDirection="-20000, -20000, -15000" UpDirection="0,0,1" FieldOfView="45"/>
                    </helix:HelixViewport3D.DefaultCamera>
                    <helix:DefaultLights/>
                    <helix:GridLinesVisual3D x:Name="GridLines" Width="60000" Length="60000" MinorDistance="1000" MajorDistance="5000" Normal="0,0,1" Thickness="2" Fill="#30CCCCCC"/>
                </helix:HelixViewport3D>

                <!-- 뷰포트 우측 상단 플로팅 버튼 -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="15,15,45,15" Orientation="Horizontal">
                    <Button Content="화면 복사" Click="BtnCopyToClipboard_Click" Margin="0,0,8,0" FontWeight="SemiBold" Background="#FF4CAF50"/>
                    <Button Content="뷰 초기화" Click="BtnZoomExtents_Click" Margin="0,0,8,0" FontWeight="SemiBold" Background="#FF007ACC"/>
                    <Button Content="클리어" Click="BtnClear3D_Click" FontWeight="SemiBold" Background="#FFC62828"/>
                </StackPanel>

                <!-- 로딩 바 -->
                <Grid x:Name="GridLoading" Background="#90000000" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="12" Background="#FF333333" Foreground="#FF007ACC"/>
                        <TextBlock x:Name="TxtLoading" Text="데이터 로딩 중..." HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="13" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 분할 바 -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#FF3F3F46"/>

            <!-- 우측 패널: 분석 결과 및 특징점 정보 -->
            <Grid Grid.Column="4" Background="#FF2D2D30">
                <TabControl Background="Transparent" BorderThickness="0" Margin="5">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" Margin="0,0,2,0" Padding="12,6" Background="#FF2D2D30" BorderBrush="#FF555555" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#FF007ACC" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="#FF3E3E42" />
                                                <Setter Property="Foreground" Value="#FFAAAAAA" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- 탭 1: 자동 라우팅 결과 목록 -->
                    <TabItem Header="자동설계 결과">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#FF252526" Padding="10" Margin="5" CornerRadius="4">
                                <TextBlock x:Name="TxtRouteResult" Text="자동 라우팅을 실행해주세요." Foreground="#FF007ACC" FontWeight="Bold" FontSize="13"/>
                            </Border>

                            <DataGrid x:Name="DgRouteResults" Grid.Row="1" Margin="5,0,5,5" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgRouteResults_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="유틸리티" Binding="{Binding Utility}" Width="1.2*" MinWidth="80"/>
                                    <DataGridTextColumn Header="결과" Binding="{Binding Status}" Width="0.8*" MinWidth="60"/>
                                    <DataGridTextColumn Header="길이(mm)" Binding="{Binding LengthText}" Width="1*" MinWidth="80"/>
                                    <DataGridTextColumn Header="꺾임" Binding="{Binding TurnsText}" Width="0.6*" MinWidth="40"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#FF3F3F46"/>

                            <Border Grid.Row="3" Background="#FF1E1E1E" BorderBrush="#FF3F3F46" BorderThickness="1" Margin="5" Padding="8" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="선택 경로 생성 세부 프로세스 로그" Foreground="#FFFFB900" FontWeight="Bold" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox Grid.Row="1" x:Name="TxtRouteDetailLog" Background="Transparent" Foreground="#FFD4D4D4" BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Text="경로를 선택하면 생성 프로세스 상세 정보가 여기에 나타납니다."/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- 탭 2: 로드된 기존설계 특징점 데이터 -->
                    <TabItem Header="기존설계 특징점">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                            <StackPanel>
                                <TextBlock Text="분석된 유틸리티 그룹별 특징 프로필" Foreground="#FF007ACC" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="LstFeatureProfiles">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FF252526" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding UtilityGroup}" FontWeight="Bold" Foreground="#FFFFB900" FontSize="12" Margin="0,0,0,5"/>
                                                    <TextBlock Margin="0,2">
                                                        <Run Text="• 선호 Rack Z고도: " Foreground="#FFAAAAAA"/>
                                                        <Run Text="{Binding PreferredRackZsString, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2">
                                                        <Run Text="• 선호 접속면: " Foreground="#FFAAAAAA"/>
                                                        <Run Text="출발: "/><Run Text="{Binding PreferredSourceFace, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=" / 종단: "/><Run Text="{Binding PreferredTargetFace, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2">
                                                        <Run Text="• 공용 척추선(Spine) 노드수: " Foreground="#FFAAAAAA"/>
                                                        <Run Text="{Binding SpinePointsCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2">
                                                        <Run Text="• 유사설계(Top-K) 등록 수: " Foreground="#FFAAAAAA"/>
                                                        <Run Text="{Binding TopKCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 선택된 작업의 Top-K 유사 설계 -->
                                <Border BorderBrush="#FF3F3F46" BorderThickness="0,1,0,0" Margin="0,15,0,0" Padding="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="선택된 작업의 Top-K 유사설계" Foreground="#FFFFB900" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                                        <TextBlock x:Name="TxtSelectedTaskInfo" Text="작업을 선택하면 유사설계 정보가 여기에 표시됩니다." Foreground="#FFAAAAAA" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="11"/>
                                        <ItemsControl x:Name="LstTopKDesigns">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding RoutePathGuid}" FontWeight="Bold" Foreground="#FF007ACC" FontSize="11" TextWrapping="NoWrap" Margin="0,0,0,4"/>
                                                            <TextBlock Margin="0,2" FontSize="11">
                                                                <Run Text="• 순위: " Foreground="#FFAAAAAA"/><Run Text="{Binding Rank}" FontWeight="Bold" Foreground="Yellow"/>
                                                                <Run Text=" | 유사도: " Foreground="#FFAAAAAA"/><Run Text="{Binding SimilarityScore, StringFormat={}{0:F3}}" FontWeight="SemiBold" Foreground="White"/>
                                                            </TextBlock>
                                                            <TextBlock Margin="0,2" FontSize="11">
                                                                <Run Text="• 유틸리티: " Foreground="#FFAAAAAA"/><Run Text="{Binding Utility}" FontWeight="SemiBold" Foreground="White"/>
                                                                <Run Text=" | 관경: " Foreground="#FFAAAAAA"/><Run Text="{Binding Size}" FontWeight="SemiBold" Foreground="White"/>
                                                            </TextBlock>
                                                            <TextBlock Margin="0,2" FontSize="11">
                                                                <Run Text="• 총 길이: " Foreground="#FFAAAAAA"/><Run Text="{Binding TotalLengthMm, StringFormat={}{0:N0} mm}" FontWeight="SemiBold" Foreground="White"/>
                                                                <Run Text=" | 꺾임: " Foreground="#FFAAAAAA"/><Run Text="{Binding StepCount}" FontWeight="SemiBold" Foreground="White"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
